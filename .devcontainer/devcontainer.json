{
  "name": "Love_Common_test - LaTeX",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.makefile-tools",
        "James-Yu.latex-workshop",
        "valentjn.vscode-ltex",
        "GitHub.copilot"
      ],
      "settings": {
        "latex-workshop.latex.recipes": [
          {
            "name": "pLaTeX + dvipdfmx",
            "tools": ["platex", "dvipdfmx"]
          }
        ],
        "latex-workshop.latex.tools": [
          {
            "name": "platex",
            "command": "platex",
            "args": ["-interaction=nonstopmode", "%DOC%"]
          },
          {
            "name": "dvipdfmx",
            "command": "dvipdfmx",
            "args": ["%DOCFILE%.dvi"]
          }
        ],
        "latex-workshop.latex.autoBuild.run": "onFileChange",
        "latex-workshop.latex.outDir": "%DIR%"
      }
    }
  },

  "containerEnv": {
    "TZ": "Asia/Tokyo"
  },

  "remoteUser": "vscode",

  "postCreateCommand": "apt-get update && apt-get install -y texlive-full ghostscript",

  "mounts": [
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.ssh,target=/home/vscode/.ssh,readonly"
  ]
}
